{
  "name": "andrewdyer/cors-response-emitter",
  "description": "A CORS-aware response emitter for Slim Framework applications, designed to ensure consistent and secure HTTP responses",
  "keywords": ["php", "slim", "cors", "http", "psr-7", "middleware"],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "AndrewDyer\\CorsResponseEmitter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AndrewDyer\\CorsResponseEmitter\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "slim/psr7": "^1.8",
    "slim/slim": "^4.12"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
